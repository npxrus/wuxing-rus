---
// Карточка галереи (заглушка с промптом)
export interface Props {
  id: string;
  title: string;
  category: string;
  categoryName: string;
  prompt: string;
  placeholderColor: string;
  icon: string;
  description: string;
}

const { id, title, category, categoryName, prompt, placeholderColor, icon, description } = Astro.props;
---

<div class="gallery-card" data-id={id} data-category={category}>
  <div class="image-placeholder" style={`background: linear-gradient(135deg, ${placeholderColor} 0%, ${placeholderColor}80 100%);`}>
    <div class="placeholder-content">
      <div class="placeholder-icon">{icon}</div>
      <div class="placeholder-text">Изображение скоро появится</div>
      <div class="placeholder-note">Сгенерируйте по промпту</div>
    </div>
  </div>
  
  <div class="card-info">
    <h3 class="card-title">{title}</h3>
    <span class="category-tag">{categoryName}</span>
    <p class="card-description">{description}</p>
  </div>
  
  <button class="view-prompt-btn" data-prompt={prompt} data-title={title}>
    📋 Посмотреть промпт
  </button>
</div>

<style>
  .gallery-card {
    background: var(--bg-card);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
    height: 100%;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border-color);
  }
  
  .gallery-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  
  .image-placeholder {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  
  .placeholder-content {
    text-align: center;
    color: white;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
  }
  
  .placeholder-icon {
    font-size: 4rem;
    margin-bottom: 0.5rem;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
  }
  
  .placeholder-text {
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }
  
  .placeholder-note {
    font-size: 0.7rem;
    opacity: 0.8;
  }
  
  .card-info {
    padding: 1rem;
    flex: 1;
  }
  
  .card-title {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
  }
  
  .category-tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: var(--bg-secondary);
    border-radius: 12px;
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  
  .card-description {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.4;
    margin: 0;
  }
  
  .view-prompt-btn {
    margin: 0 1rem 1rem 1rem;
    padding: 0.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-md);
    color: var(--text-accent);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  
  .view-prompt-btn:hover {
    background: var(--text-accent);
    color: var(--bg-primary);
    border-color: var(--text-accent);
  }
</style>