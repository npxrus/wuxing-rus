---
// Карточка торгового пути
export interface Props {
  route: {
    name: string;
    connects: string[];
    length: string;
    dangers: string[];
    goods: string[];
    icon: string;
  };
}

const { route } = Astro.props;
---

<div class="trade-route-card">
  <div class="route-header">
    <div class="route-icon">{route.icon}</div>
    <div class="route-title">
      <h3>{route.name}</h3>
      <span class="route-length">📏 {route.length}</span>
    </div>
  </div>
  
  <div class="route-connects">
    <strong>🔗 Соединяет:</strong>
    <div class="connects-list">
      {route.connects.map(connect => <span class="connect-tag">{connect}</span>)}
    </div>
  </div>
  
  <div class="route-goods">
    <strong>📦 Товары:</strong>
    <ul>
      {route.goods.map(good => <li>{good}</li>)}
    </ul>
  </div>
  
  <div class="route-dangers">
    <strong>⚠️ Опасности:</strong>
    <ul>
      {route.dangers.map(danger => <li>{danger}</li>)}
    </ul>
  </div>
</div>

<style>
  .trade-route-card {
    background: var(--bg-card);
    border-radius: var(--border-radius-lg);
    padding: 1rem;
    transition: transform var(--transition-fast), box-shadow var(--transition-normal);
    border: 1px solid var(--border-color);
    height: 100%;
  }
  
  .trade-route-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  
  .route-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }
  
  .route-icon {
    font-size: 1.8rem;
  }
  
  .route-title {
    flex: 1;
  }
  
  .route-title h3 {
    margin: 0 0 0.25rem 0;
    font-size: 1rem;
  }
  
  .route-length {
    font-size: 0.7rem;
    color: var(--text-muted);
  }
  
  .route-connects, .route-goods, .route-dangers {
    margin-top: 0.5rem;
    font-size: 0.8rem;
  }
  
  .connects-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.25rem;
  }
  
  .connect-tag {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    background: var(--bg-secondary);
    border-radius: 12px;
    color: var(--text-accent);
  }
  
  .route-goods ul, .route-dangers ul {
    margin: 0.25rem 0 0 1.25rem;
    color: var(--text-muted);
  }
  
  .route-goods li, .route-dangers li {
    margin-bottom: 0.15rem;
  }
</style>