---
// Карточка этапа обучения
export interface Props {
  name: string;
  ageRange: string;
  description: string;
  rituals: string[];
  outcomes: string[];
  icon: string;
  index: number;
}

const { name, ageRange, description, rituals, outcomes, icon, index } = Astro.props;

const isLeft = index % 2 === 0;
const timelineClass = isLeft ? 'timeline-left' : 'timeline-right';
---

<div class={`timeline-card ${timelineClass}`}>
  <div class="timeline-marker">
    <span class="timeline-icon">{icon}</span>
    <div class="timeline-line"></div>
  </div>
  
  <div class="timeline-content">
    <div class="stage-header">
      <h3>{name}</h3>
      <span class="age-badge">{ageRange}</span>
    </div>
    <p class="stage-description">{description}</p>
    
    <div class="stage-details">
      <div class="stage-rituals">
        <strong>🕯️ Ритуалы:</strong>
        <ul>
          {rituals.map(ritual => <li>{ritual}</li>)}
        </ul>
      </div>
      <div class="stage-outcomes">
        <strong>🎯 Результат:</strong>
        <ul>
          {outcomes.map(outcome => <li>{outcome}</li>)}
        </ul>
      </div>
    </div>
  </div>
</div>

<style>
  .timeline-card {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
    position: relative;
  }
  
  .timeline-left {
    flex-direction: row;
  }
  
  .timeline-right {
    flex-direction: row-reverse;
  }
  
  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }
  
  .timeline-icon {
    width: 50px;
    height: 50px;
    background: var(--bg-secondary);
    border: 2px solid var(--text-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    z-index: 2;
    background: var(--bg-card);
  }
  
  .timeline-line {
    width: 2px;
    flex: 1;
    background: var(--border-color);
    margin: 0.5rem 0;
  }
  
  .timeline-card:last-child .timeline-line {
    display: none;
  }
  
  .timeline-content {
    flex: 1;
    background: var(--bg-card);
    border-radius: var(--border-radius-md);
    padding: 1.25rem;
    margin-bottom: 1rem;
    border: 1px solid var(--border-color);
    transition: transform var(--transition-fast);
  }
  
  .timeline-content:hover {
    transform: translateX(5px);
    border-color: var(--text-accent);
  }
  
  .timeline-right .timeline-content:hover {
    transform: translateX(-5px);
  }
  
  .stage-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  
  .stage-header h3 {
    margin: 0;
    font-size: 1.2rem;
  }
  
  .age-badge {
    background: var(--text-accent);
    color: var(--bg-primary);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
  }
  
  .stage-description {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  
  .stage-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    font-size: 0.85rem;
  }
  
  .stage-details strong {
    color: var(--text-accent);
  }
  
  .stage-details ul {
    margin: 0.25rem 0 0 1.25rem;
    color: var(--text-muted);
  }
  
  .stage-details li {
    margin-bottom: 0.2rem;
  }
  
  @media (max-width: 768px) {
    .timeline-card {
      flex-direction: column !important;
    }
    
    .timeline-marker {
      flex-direction: row;
      justify-content: center;
      gap: 0;
    }
    
    .timeline-line {
      width: 100%;
      height: 2px;
      margin: 0 0.5rem;
    }
    
    .stage-details {
      grid-template-columns: 1fr;
    }
    
    .timeline-content:hover {
      transform: translateY(-5px) !important;
    }
  }
</style>