---
// Карточка магической касты
export interface Props {
  name: string;
  description: string;
  learningMethod: string;
  specializations: string[];
  tools: string[];
  icon: string;
  color: string;
}

const { name, description, learningMethod, specializations, tools, icon, color } = Astro.props;
---

<div class="caste-card">
  <div class="caste-header" style={`border-bottom-color: ${color}`}>
    <div class="caste-icon" style={`background: ${color}20; color: ${color}`}>
      <span>{icon}</span>
    </div>
    <h3 class="caste-name">{name}</h3>
  </div>
  
  <p class="caste-description">{description}</p>
  
  <div class="caste-section">
    <div class="section-title">📖 Способ обучения</div>
    <p class="section-content">{learningMethod}</p>
  </div>
  
  <div class="caste-section">
    <div class="section-title">✨ Специализации</div>
    <div class="tags-list">
      {specializations.map(spec => (
        <span class="tag">{spec}</span>
      ))}
    </div>
  </div>
  
  <div class="caste-section">
    <div class="section-title">🛠️ Инструменты</div>
    <div class="tools-list">
      {tools.map(tool => (
        <div class="tool-item">
          <span class="tool-marker">•</span>
          <span>{tool}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .caste-card {
    background: var(--bg-card);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
    height: 100%;
    border: 1px solid var(--border-color);
  }
  
  .caste-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  
  .caste-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.25rem 0.75rem 1.25rem;
    border-bottom: 3px solid;
  }
  
  .caste-icon {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
  }
  
  .caste-name {
    margin: 0;
    font-size: 1.3rem;
  }
  
  .caste-description {
    padding: 1rem 1.25rem;
    color: var(--text-secondary);
    line-height: 1.6;
    border-bottom: 1px solid var(--border-color);
  }
  
  .caste-section {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
  }
  
  .caste-section:last-child {
    border-bottom: none;
  }
  
  .section-title {
    font-weight: 600;
    color: var(--text-accent);
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }
  
  .section-content {
    color: var(--text-muted);
    line-height: 1.5;
    font-size: 0.9rem;
  }
  
  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .tag {
    background: var(--bg-secondary);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
    color: var(--text-secondary);
  }
  
  .tools-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  
  .tool-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  
  .tool-marker {
    color: var(--text-accent);
  }
</style>