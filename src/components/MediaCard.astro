---
// Карточка медиа-продукта
export interface Props {
  item: {
    id: string;
    title: string;
    type: string;
    typeName: string;
    status: string;
    statusName: string;
    description: string;
    placeholderColor: string;
    icon: string;
    author?: string;
    artist?: string;
    developer?: string;
    year?: string;
    pages?: number;
    platform?: string[];
  };
}

const { item } = Astro.props;

const statusColors = {
  published: { bg: 'rgba(34, 197, 94, 0.2)', text: '#22c55e' },
  'coming-soon': { bg: 'rgba(249, 115, 22, 0.2)', text: '#f97316' },
  'in-development': { bg: 'rgba(234, 179, 8, 0.2)', text: '#eab308' },
  planned: { bg: 'rgba(107, 114, 128, 0.2)', text: '#9ca3af' },
};

const statusColor = statusColors[item.status as keyof typeof statusColors] || statusColors.planned;

const typeIcons = {
  book: '📖',
  comic: '🎨',
  game: '🎮',
  rpg: '🎲',
};
---

<div class="media-card" style={`border-left-color: ${item.placeholderColor}`}>
  <div class="media-header">
    <div class="media-icon" style={`background: ${item.placeholderColor}20`}>
      <span>{item.icon}</span>
    </div>
    <div class="media-title">
      <h3>{item.title}</h3>
      <div class="media-meta">
        <span class="media-type">
          {typeIcons[item.type as keyof typeof typeIcons]} {item.typeName}
        </span>
        <span class="media-status" style={`background: ${statusColor.bg}; color: ${statusColor.text}`}>
          {item.statusName}
        </span>
      </div>
    </div>
  </div>
  
  <p class="media-description">{item.description}</p>
  
  <div class="media-details">
    {item.author && (
      <div class="media-detail">
        <span class="detail-icon">✍️</span>
        <span>Автор: {item.author}</span>
      </div>
    )}
    {item.artist && (
      <div class="media-detail">
        <span class="detail-icon">🎨</span>
        <span>Художник: {item.artist}</span>
      </div>
    )}
    {item.developer && (
      <div class="media-detail">
        <span class="detail-icon">💻</span>
        <span>Разработчик: {item.developer}</span>
      </div>
    )}
    {item.year && (
      <div class="media-detail">
        <span class="detail-icon">📅</span>
        <span>Год: {item.year}</span>
      </div>
    )}
    {item.pages && (
      <div class="media-detail">
        <span class="detail-icon">📄</span>
        <span>Страниц: {item.pages}</span>
      </div>
    )}
    {item.platform && item.platform.length > 0 && (
      <div class="media-detail">
        <span class="detail-icon">🎮</span>
        <span>Платформы: {item.platform.join(', ')}</span>
      </div>
    )}
  </div>
  
  <div class="media-placeholder" style={`background: ${item.placeholderColor}20; border-color: ${item.placeholderColor}`}>
    <span class="placeholder-icon">{item.icon}</span>
    <span class="placeholder-text">Скоро здесь появится обложка</span>
  </div>
</div>

<style>
  .media-card {
    background: var(--bg-card);
    border-radius: var(--border-radius-lg);
    padding: 1.25rem;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
    border: 1px solid var(--border-color);
    border-left-width: 4px;
    border-left-style: solid;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  
  .media-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  
  .media-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  
  .media-icon {
    width: 55px;
    height: 55px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
  }
  
  .media-title {
    flex: 1;
  }
  
  .media-title h3 {
    margin: 0 0 0.25rem 0;
    font-size: 1.1rem;
  }
  
  .media-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  
  .media-type {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    background: var(--bg-secondary);
    border-radius: 12px;
    color: var(--text-muted);
  }
  
  .media-status {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
  }
  
  .media-description {
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }
  
  .media-details {
    margin-bottom: 1rem;
    flex: 1;
  }
  
  .media-detail {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }
  
  .detail-icon {
    font-size: 0.85rem;
  }
  
  .media-placeholder {
    margin-top: 0.5rem;
    padding: 1rem;
    border-radius: var(--border-radius-md);
    border: 1px dashed;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  
  .placeholder-icon {
    font-size: 1.5rem;
  }
  
  .placeholder-text {
    font-size: 0.7rem;
    color: var(--text-muted);
  }
</style>