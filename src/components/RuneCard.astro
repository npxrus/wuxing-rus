---
// Карточка руны
import ElementBadge from './ElementBadge.astro';

export interface Props {
  rune: {
    name: string;
    element: 'wood' | 'fire' | 'earth' | 'metal' | 'water' | 'void';
    color: string;
    meaning: string;
    magicUse: string;
    icon: string;
    isForbidden?: boolean;
  };
}

const { rune } = Astro.props;

const elementDisplay = rune.element === 'void' ? null : rune.element;
const voidColor = '#6b7280';
---

<div class="rune-card" style={`border-left-color: ${rune.element === 'void' ? voidColor : `var(--element-${rune.element})`}`}>
  <div class="rune-header">
    <div class="rune-icon" style={`background: ${rune.element === 'void' ? `${voidColor}20` : `var(--element-${rune.element})20`}`}>
      {rune.icon}
    </div>
    <div class="rune-title">
      <h3>{rune.name}</h3>
      {elementDisplay && <ElementBadge element={elementDisplay} size="small" />}
      {!elementDisplay && <span class="void-badge">Пустая руна</span>}
      {rune.isForbidden && <span class="forbidden-badge">⚠️ Запрещена</span>}
    </div>
  </div>
  
  <div class="rune-meaning">
    <strong>📖 Значение:</strong> {rune.meaning}
  </div>
  
  <div class="rune-magic">
    <strong>✨ Магическое применение:</strong> {rune.magicUse}
  </div>
</div>

<style>
  .rune-card {
    background: var(--bg-card);
    border-radius: var(--border-radius-md);
    padding: 1rem;
    transition: transform var(--transition-fast), box-shadow var(--transition-normal);
    border: 1px solid var(--border-color);
    border-left-width: 4px;
    border-left-style: solid;
  }
  
  .rune-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  
  .rune-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  
  .rune-icon {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
  }
  
  .rune-title {
    flex: 1;
  }
  
  .rune-title h3 {
    margin: 0 0 0.25rem 0;
    font-size: 1rem;
  }
  
  .void-badge {
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    background: var(--bg-secondary);
    border-radius: 12px;
    color: var(--text-muted);
  }
  
  .forbidden-badge {
    font-size: 0.65rem;
    padding: 0.2rem 0.5rem;
    background: rgba(239, 68, 68, 0.2);
    border-radius: 12px;
    color: #ef4444;
  }
  
  .rune-meaning, .rune-magic {
    font-size: 0.8rem;
    margin-top: 0.5rem;
    color: var(--text-secondary);
  }
</style>