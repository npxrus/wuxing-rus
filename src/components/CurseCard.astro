---
// Карточка проклятия
export interface Props {
  name: string;
  type: 'personal' | 'local';
  effect: string;
  removal: string;
  duration: string;
  icon: string;
}

const { name, type, effect, removal, duration, icon } = Astro.props;

const typeNames = { personal: 'Личное', local: 'Местное' };
const typeColors = { personal: '#8b5cf6', local: '#f59e0b' };
---

<div class="curse-card" style={`border-left-color: ${typeColors[type]}`}>
  <div class="curse-header">
    <div class="curse-icon">{icon}</div>
    <div class="curse-title">
      <h3>{name}</h3>
      <span class="curse-type" style={`background: ${typeColors[type]}20; color: ${typeColors[type]}`}>
        {typeNames[type]}
      </span>
    </div>
  </div>
  
  <div class="curse-effect">
    <strong>💀 Эффект:</strong>
    <p>{effect}</p>
  </div>
  
  <div class="curse-removal">
    <strong>🔮 Снятие:</strong>
    <p>{removal}</p>
  </div>
  
  <div class="curse-duration">
    <strong>⏰ Длительность:</strong>
    <p>{duration}</p>
  </div>
</div>

<style>
  .curse-card {
    background: var(--bg-card);
    border-radius: var(--border-radius-lg);
    padding: 1.25rem;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
    border: 1px solid var(--border-color);
    border-left-width: 4px;
    border-left-style: solid;
    height: 100%;
  }
  
  .curse-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  
  .curse-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  
  .curse-icon {
    font-size: 2rem;
  }
  
  .curse-title {
    flex: 1;
  }
  
  .curse-title h3 {
    margin: 0 0 0.25rem 0;
    font-size: 1.2rem;
  }
  
  .curse-type {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
  }
  
  .curse-effect, .curse-removal, .curse-duration {
    margin-top: 0.75rem;
    font-size: 0.85rem;
  }
  
  .curse-effect p, .curse-removal p, .curse-duration p {
    margin: 0.25rem 0 0 0;
    color: var(--text-muted);
  }
</style>