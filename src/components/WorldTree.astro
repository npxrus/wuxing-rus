---
// Компонент для отображения Мирового Дуба (визуализация)
// Показывает три мира, соединённые древом
---

<div class="world-tree">
  <div class="tree-container">
    <div class="tree-canopy">
      <div class="realm prav">
        <div class="realm-icon">⭐</div>
        <div class="realm-name">Правь</div>
        <div class="realm-desc">Небесный мир<br/>Звёздные духи</div>
      </div>
    </div>
    
    <div class="tree-trunk">
      <div class="trunk-core">
        <div class="tree-icon">🌳</div>
        <div class="tree-name">Мировой Дуб</div>
        <div class="tree-stats">
          <span>📏 500 м</span>
          <span>🌿 Обхват &gt;100 м</span>
          <span>☀️ Крона 800 м</span>
        </div>
      </div>
    </div>
    
    <div class="tree-roots">
      <div class="realm yav">
        <div class="realm-icon">🌍</div>
        <div class="realm-name">Явь</div>
        <div class="realm-desc">Срединный мир<br/>Пять Княжеств</div>
      </div>
      <div class="realm nav">
        <div class="realm-icon">🌙</div>
        <div class="realm-name">Навь</div>
        <div class="realm-desc">Подземный мир<br/>Тени и забытые</div>
      </div>
    </div>
  </div>
  
  <div class="tree-features">
    <div class="feature">
      <span class="feature-icon">🌱</span>
      <span>Источник Начал у основания</span>
    </div>
    <div class="feature">
      <span class="feature-icon">🪹</span>
      <span>Гнездо Вечности на высоте 100 м</span>
    </div>
    <div class="feature">
      <span class="feature-icon">🚪</span>
      <span>Дверь Миров — арка из ветвей</span>
    </div>
    <div class="feature">
      <span class="feature-icon">🕊️</span>
      <span>Журавли-Наставники на верхних ветвях</span>
    </div>
  </div>
</div>

<style>
  .world-tree {
    background: linear-gradient(180deg, 
      rgba(196, 167, 71, 0.05) 0%,
      rgba(30, 30, 30, 0.8) 30%,
      rgba(45, 90, 39, 0.1) 70%,
      rgba(45, 45, 74, 0.2) 100%
    );
    border-radius: var(--border-radius-lg);
    padding: 2rem;
    margin: 2rem 0;
  }
  
  .tree-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }
  
  .tree-canopy {
    text-align: center;
    margin-bottom: 1rem;
  }
  
  .realm {
    background: var(--bg-card);
    border-radius: var(--border-radius-md);
    padding: 1rem 1.5rem;
    margin: 0.5rem;
    border: 1px solid var(--border-color);
    transition: transform var(--transition-fast);
  }
  
  .realm:hover {
    transform: scale(1.05);
  }
  
  .prav {
    border-top: 3px solid #c4a747;
    background: linear-gradient(135deg, var(--bg-card) 0%, rgba(196, 167, 71, 0.1) 100%);
  }
  
  .realm-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  
  .realm-name {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  
  .realm-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  
  .tree-trunk {
    display: flex;
    justify-content: center;
    margin: 1rem 0;
    position: relative;
  }
  
  .trunk-core {
    background: linear-gradient(180deg, #2a1a0a 0%, #3d2a1a 100%);
    border-radius: 50px;
    padding: 1.5rem 2rem;
    text-align: center;
    min-width: 200px;
    border: 1px solid #5a3a2a;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }
  
  .tree-icon {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }
  
  .tree-name {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: #c4a747;
  }
  
  .tree-stats {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    font-size: 0.7rem;
    color: var(--text-muted);
  }
  
  .tree-roots {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1rem;
  }
  
  .yav {
    border-bottom: 3px solid #4a8a42;
    background: linear-gradient(135deg, var(--bg-card) 0%, rgba(74, 138, 66, 0.1) 100%);
  }
  
  .nav {
    border-bottom: 3px solid #5a5a8a;
    background: linear-gradient(135deg, var(--bg-card) 0%, rgba(90, 90, 138, 0.1) 100%);
  }
  
  .tree-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.75rem;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
  }
  
  .feature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }
  
  .feature-icon {
    font-size: 1.1rem;
  }
  
  @media (max-width: 640px) {
    .world-tree {
      padding: 1rem;
    }
    
    .trunk-core {
      padding: 1rem;
      min-width: auto;
    }
    
    .tree-stats {
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
    }
    
    .realm {
      padding: 0.75rem 1rem;
    }
    
    .realm-name {
      font-size: 1rem;
    }
  }
</style>