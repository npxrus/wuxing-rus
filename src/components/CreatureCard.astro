---
// Карточка существа
import ElementBadge from './ElementBadge.astro';
import { DANGER_LEVELS } from '@data/dangerLevels';
import type { Creature } from '@types/creature.types';
import { withBase } from '@/utils/paths';

export interface Props {
  creature: Creature;
}

const { creature } = Astro.props;
const { 
  id, 
  name, 
  category, 
  categoryName, 
  element, 
  description, 
  appearance, 
  habitat, 
  abilities, 
  dangerLevel, 
  icon,
  traces,
  sounds,
  smell,
  tamable 
} = creature;

const dangerInfo = DANGER_LEVELS[dangerLevel] || DANGER_LEVELS.low;
const categoryClass = category === 'higher' ? 'category-higher' : '';
---

<div class={`creature-card ${element ? `creature-${element}` : ''} ${categoryClass}`}>
  <div class="card-header">
    <div class="creature-icon">{icon}</div>
    <div class="creature-title">
      <h3>{name}</h3>
      <div class="creature-meta">
        <span class="category-badge">{categoryName}</span>
        {element && <ElementBadge element={element} size="small" />}
        <span class="danger-badge" style={`background: ${dangerInfo.color}20; color: ${dangerInfo.color}; border-color: ${dangerInfo.color}`}>
          {dangerInfo.icon} {dangerInfo.name}
        </span>
        {tamable && <span class="tamable-badge">🐕 Можно приручить</span>}
      </div>
    </div>
  </div>
  
  <p class="creature-description">{description}</p>
  
  <div class="creature-details">
    <div class="detail-item">
      <span class="detail-icon">👁️</span>
      <div>
        <strong>Облик</strong>
        <p>{appearance}</p>
      </div>
    </div>
    
    <div class="detail-item">
      <span class="detail-icon">🏞️</span>
      <div>
        <strong>Обитание</strong>
        <p>{habitat}</p>
      </div>
    </div>
    
    <div class="detail-item">
      <span class="detail-icon">✨</span>
      <div>
        <strong>Способности</strong>
        <ul>
          {abilities.slice(0, 3).map(ability => <li>{ability}</li>)}
        </ul>
      </div>
    </div>
    
    {traces && (
      <div class="detail-item">
        <span class="detail-icon">👣</span>
        <div>
          <strong>Следы</strong>
          <p>{traces}</p>
        </div>
      </div>
    )}
    
    {sounds && (
      <div class="detail-item">
        <span class="detail-icon">🔊</span>
        <div>
          <strong>Звуки</strong>
          <p>{sounds}</p>
        </div>
      </div>
    )}
    
    {smell && (
      <div class="detail-item">
        <span class="detail-icon">👃</span>
        <div>
          <strong>Запах</strong>
          <p>{smell}</p>
        </div>
      </div>
    )}
  </div>
  
  <a href={withBase(`/creatures/${id}`)} class="card-link">
    Узнать больше о существе →
  </a>
</div>

<style>
  .creature-card {
    background: var(--bg-card);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
    height: 100%;
    display: flex;
    flex-direction: column;
    border-left: 4px solid;
  }
  
  .creature-wood { border-left-color: var(--element-wood); }
  .creature-fire { border-left-color: var(--element-fire); }
  .creature-earth { border-left-color: var(--element-earth); }
  .creature-metal { border-left-color: var(--element-metal); }
  .creature-water { border-left-color: var(--element-water); }
  
  .category-higher {
    background: linear-gradient(135deg, var(--bg-card) 0%, rgba(212, 175, 55, 0.05) 100%);
  }
  
  .creature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  
  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.25rem 0.5rem 1.25rem;
  }
  
  .creature-icon {
    font-size: 2.5rem;
  }
  
  .creature-title {
    flex: 1;
  }
  
  .creature-title h3 {
    margin: 0 0 0.25rem 0;
    font-size: 1.25rem;
  }
  
  .creature-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  
  .category-badge {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    background: var(--bg-secondary);
    color: var(--text-muted);
  }
  
  .danger-badge {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    border: 1px solid;
  }
  
  .tamable-badge {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    background: rgba(34, 197, 94, 0.2);
    color: #22c55e;
  }
  
  .creature-description {
    padding: 0 1.25rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }
  
  .creature-details {
    padding: 0 1.25rem;
    flex: 1;
  }
  
  .detail-item {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 0.85rem;
  }
  
  .detail-icon {
    font-size: 1rem;
    flex-shrink: 0;
  }
  
  .detail-item strong {
    display: block;
    margin-bottom: 0.2rem;
    color: var(--text-primary);
  }
  
  .detail-item p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.4;
  }
  
  .detail-item ul {
    margin: 0;
    padding-left: 1rem;
    color: var(--text-muted);
  }
  
  .detail-item li {
    margin-bottom: 0.15rem;
  }
  
  .card-link {
    display: block;
    margin: 1rem 1.25rem 1.25rem 1.25rem;
    padding: 0.5rem 0;
    text-align: center;
    background: var(--bg-secondary);
    border-radius: var(--border-radius-md);
    color: var(--text-accent);
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  
  .card-link:hover {
    background: var(--text-accent);
    color: var(--bg-primary);
  }
</style>