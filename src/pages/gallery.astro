---
// Страница «Галерея»
import BaseLayout from '@layouts/BaseLayout.astro';
import GalleryCard from '@components/GalleryCard.astro';
import { GALLERY_IMAGES, GALLERY_CATEGORIES } from '@data/gallery';
---

<BaseLayout title="Галерея">
  <div class="page-header">
    <h1>🖼️ Галерея Царства Пяти Начал</h1>
    <p class="page-description">
      Изображения мира, существ и княжеств. Пока это заглушки — вы можете сгенерировать их с помощью промптов
    </p>
  </div>

  <!-- Фильтры -->
  <div class="filters-section">
    <div class="filter-buttons">
      {GALLERY_CATEGORIES.map(cat => (
        <button 
          class="filter-btn" 
          data-filter={cat.id}
          data-category={cat.id}
        >
          <span class="filter-icon">{cat.icon}</span>
          {cat.name}
        </button>
      ))}
    </div>
  </div>

  <!-- Статистика -->
  <div class="stats-bar">
    <div class="stat">
      <span class="stat-value">{GALLERY_IMAGES.length}</span>
      <span class="stat-label">изображений</span>
    </div>
    <div class="stat">
      <span class="stat-value">{GALLERY_CATEGORIES.length - 1}</span>
      <span class="stat-label">категорий</span>
    </div>
  </div>

  <!-- Сетка галереи -->
  <div class="gallery-grid" id="galleryGrid">
    {GALLERY_IMAGES.map(image => (
      <GalleryCard
        id={image.id}
        title={image.title}
        category={image.category}
        categoryName={image.categoryName}
        prompt={image.prompt}
        placeholderColor={image.placeholderColor}
        icon={image.icon}
        description={image.description}
      />
    ))}
  </div>

  <!-- Модальное окно для промпта -->
  <div id="promptModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modalTitle">Промпт для генерации</h3>
        <button class="modal-close">&times;</button>
      </div>
      <div class="modal-body">
        <p id="modalPrompt" class="prompt-text"></p>
        <button id="copyPromptBtn" class="copy-btn">📋 Копировать промпт</button>
      </div>
    </div>
  </div>

  <!-- Инструкция по генерации -->
  <div class="info-section">
    <h3>📌 Как сгенерировать изображения</h3>
    <p>
      Для создания изображений для галереи вы можете использовать нейросеть 
      <strong>«Шедеврум»</strong> или любую другую (Midjourney, DALL-E, Kandinsky).
    </p>
    <p>Просто скопируйте промпт из карточки и вставьте в нейросеть.</p>
    <div class="tips">
      <div class="tip">
        <span class="tip-icon">🎨</span>
        <span>Используйте высокое разрешение</span>
      </div>
      <div class="tip">
        <span class="tip-icon">🎭</span>
        <span>Указывайте «фотореализм» для лучшего результата</span>
      </div>
      <div class="tip">
        <span class="tip-icon">🌅</span>
        <span>Экспериментируйте с освещением</span>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  
  .page-description {
    font-size: 1rem;
    color: var(--text-accent);
    max-width: 700px;
    margin: 0 auto;
  }
  
  .filters-section {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  
  .filter-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
  
  .filter-btn {
    padding: 0.5rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 30px;
    font-size: 0.9rem;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .filter-btn:hover {
    border-color: var(--text-accent);
    color: var(--text-accent);
  }
  
  .filter-btn.active {
    background: var(--text-accent);
    border-color: var(--text-accent);
    color: var(--bg-primary);
  }
  
  .filter-icon {
    font-size: 1rem;
  }
  
  .stats-bar {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 2rem;
    padding: 1rem;
    background: var(--bg-secondary);
    border-radius: var(--border-radius-lg);
  }
  
  .stat {
    text-align: center;
  }
  
  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-accent);
  }
  
  .stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-left: 0.3rem;
  }
  
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }
  
  /* Модальное окно */
  .modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8);
    z-index: 2000;
    align-items: center;
    justify-content: center;
  }
  
  .modal.active {
    display: flex;
  }
  
  .modal-content {
    background: var(--bg-card);
    border-radius: var(--border-radius-lg);
    max-width: 600px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    border: 1px solid var(--text-accent);
  }
  
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--border-color);
  }
  
  .modal-header h3 {
    margin: 0;
  }
  
  .modal-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--text-muted);
    cursor: pointer;
  }
  
  .modal-close:hover {
    color: var(--text-accent);
  }
  
  .modal-body {
    padding: 1.5rem;
  }
  
  .prompt-text {
    background: var(--bg-secondary);
    padding: 1rem;
    border-radius: var(--border-radius-md);
    font-family: monospace;
    font-size: 0.85rem;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
    margin-bottom: 1rem;
    max-height: 400px;
    overflow-y: auto;
  }
  
  .copy-btn {
    width: 100%;
    padding: 0.75rem;
    background: var(--text-accent);
    border: none;
    border-radius: var(--border-radius-md);
    color: var(--bg-primary);
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  
  .copy-btn:hover {
    opacity: 0.8;
    transform: translateY(-2px);
  }
  
  /* Информационная секция */
  .info-section {
    background: linear-gradient(135deg, var(--bg-secondary) 0%, transparent 100%);
    border-radius: var(--border-radius-lg);
    padding: 1.5rem;
    margin-top: 2rem;
  }
  
  .info-section h3 {
    margin-top: 0;
  }
  
  .tips {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
  }
  
  .tip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--bg-card);
    border-radius: var(--border-radius-md);
    font-size: 0.85rem;
  }
  
  .tip-icon {
    font-size: 1.2rem;
  }
  
  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
    
    .filter-buttons {
      gap: 0.5rem;
    }
    
    .filter-btn {
      padding: 0.4rem 0.8rem;
      font-size: 0.8rem;
    }
    
    .stats-bar {
      gap: 1rem;
    }
    
    .tips {
      flex-direction: column;
    }
  }
</style>

<script>
  // Фильтрация
  const filterBtns = document.querySelectorAll('.filter-btn');
  const galleryGrid = document.getElementById('galleryGrid');
  let currentFilter = 'all';
  
  function filterGallery() {
    if (!galleryGrid) return;
    
    const cards = galleryGrid.querySelectorAll('.gallery-card');
    cards.forEach(card => {
      const category = card.dataset.category;
      if (currentFilter === 'all' || category === currentFilter) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
  }
  
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      if (filter) {
        currentFilter = filter;
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        filterGallery();
      }
    });
  });
  
  // Модальное окно для промпта
  const modal = document.getElementById('promptModal');
  const modalTitle = document.getElementById('modalTitle');
  const modalPrompt = document.getElementById('modalPrompt');
  const copyBtn = document.getElementById('copyPromptBtn');
  
  function openModal(title, prompt) {
    if (modalTitle) modalTitle.textContent = `Промпт: ${title}`;
    if (modalPrompt) modalPrompt.textContent = prompt;
    if (modal) modal.classList.add('active');
  }
  
  function closeModal() {
    if (modal) modal.classList.remove('active');
  }
  
  // Обработчики для кнопок просмотра промпта
  document.querySelectorAll('.view-prompt-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const prompt = btn.dataset.prompt;
      const title = btn.dataset.title;
      if (prompt && title) {
        openModal(title, prompt);
      }
    });
  });
  
  // Закрытие модального окна
  const closeBtn = document.querySelector('.modal-close');
  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
  
  // Копирование промпта
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const promptText = modalPrompt?.textContent;
      if (promptText) {
        try {
          await navigator.clipboard.writeText(promptText);
          copyBtn.textContent = '✅ Скопировано!';
          setTimeout(() => {
            copyBtn.textContent = '📋 Копировать промпт';
          }, 2000);
        } catch (err) {
          copyBtn.textContent = '❌ Ошибка';
          setTimeout(() => {
            copyBtn.textContent = '📋 Копировать промпт';
          }, 2000);
        }
      }
    });
  }
</script>   