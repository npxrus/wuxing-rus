---
// Динамическая страница для отдельного существа
import BaseLayout from '@layouts/BaseLayout.astro';
import ElementBadge from '@components/ElementBadge.astro';
import { ALL_CREATURES } from '@data/creatures';

export async function getStaticPaths() {
  return ALL_CREATURES.map(creature => ({
    params: { id: creature.id },
    props: { creature },
  }));
}

const { creature } = Astro.props;
const { 
  name, 
  category, 
  element, 
  description, 
  appearance, 
  habitat, 
  abilities, 
  behavior, 
  interaction, 
  size, 
  icon,
  quote 
} = creature;

const categoryLabel = category === 'higher' ? 'Высшее существо' : 'Обычное существо';
---

<BaseLayout title={name}>
  <div class="page-header">
    <div class="header-icon">
      <span>{icon}</span>
    </div>
    <div class="header-text">
      <h1>{name}</h1>
      <div class="header-meta">
        <span class="category-badge">{categoryLabel}</span>
        {element && <ElementBadge element={element} size="medium" />}
      </div>
    </div>
  </div>

  <!-- Цитата -->
  {quote && (
    <div class="quote-block">
      <p class="quote-text">«{quote}»</p>
    </div>
  )}

  <!-- Описание -->
  <section class="section">
    <h2>📜 Описание</h2>
    <p class="description-text">{description}</p>
  </section>

  <!-- Две колонки -->
  <section class="section two-columns">
    <div class="column">
      <h3>👁️ Внешний облик</h3>
      <div class="info-card">
        {size && <div class="size-badge">Размер: {size}</div>}
        <p>{appearance}</p>
      </div>
    </div>
    <div class="column">
      <h3>🏞️ Обитание</h3>
      <div class="info-card">
        <p>{habitat}</p>
      </div>
    </div>
  </section>

  <!-- Способности -->
  <section class="section">
    <h2>✨ Способности</h2>
    <div class="abilities-list">
      {abilities.map(ability => (
        <div class="ability-card">
          <span class="ability-icon">⚡</span>
          <span>{ability}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Поведение -->
  <section class="section">
    <h2>🎭 Поведение</h2>
    <div class="behavior-card">
      <p>{behavior}</p>
    </div>
  </section>

  <!-- Взаимодействие -->
  <section class="section">
    <h2>🤝 Взаимодействие с человеком</h2>
    <div class="interaction-card">
      <p>{interaction}</p>
    </div>
  </section>

  <!-- Навигация назад -->
  <div class="back-link">
    <a href="/creatures">← Вернуться к списку существ</a>
  </div>
</BaseLayout>

<style>
  .page-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
    flex-wrap: wrap;
  }
  
  .header-icon {
    font-size: 4rem;
    background: var(--bg-card);
    width: 100px;
    height: 100px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--border-color);
  }
  
  .header-text h1 {
    margin: 0 0 0.5rem 0;
  }
  
  .header-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .category-badge {
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
    background: var(--bg-secondary);
    color: var(--text-muted);
  }
  
  .section {
    margin-bottom: 2.5rem;
  }
  
  .quote-block {
    background: linear-gradient(135deg, var(--bg-card) 0%, rgba(212, 175, 55, 0.05) 100%);
    border-left: 4px solid var(--text-accent);
    padding: 1.5rem;
    margin-bottom: 2rem;
    border-radius: var(--border-radius-md);
  }
  
  .quote-text {
    font-size: 1.1rem;
    font-style: italic;
    color: var(--text-primary);
    margin: 0;
  }
  
  .description-text {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }
  
  .two-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  
  .info-card, .behavior-card, .interaction-card {
    background: var(--bg-card);
    border-radius: var(--border-radius-md);
    padding: 1.25rem;
    border: 1px solid var(--border-color);
  }
  
  .size-badge {
    display: inline-block;
    background: var(--text-accent);
    color: var(--bg-primary);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-size: 0.7rem;
    margin-bottom: 0.75rem;
  }
  
  .abilities-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  
  .ability-card {
    background: var(--bg-card);
    border-radius: 30px;
    padding: 0.5rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--border-color);
    transition: all var(--transition-fast);
  }
  
  .ability-card:hover {
    border-color: var(--text-accent);
    transform: translateY(-2px);
  }
  
  .ability-icon {
    font-size: 1rem;
  }
  
  .back-link {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    text-align: center;
  }
  
  .back-link a {
    color: var(--text-accent);
    text-decoration: none;
  }
  
  .back-link a:hover {
    text-decoration: underline;
  }
  
  @media (max-width: 768px) {
    .page-header {
      flex-direction: column;
      text-align: center;
    }
    
    .header-meta {
      justify-content: center;
    }
    
    .two-columns {
      grid-template-columns: 1fr;
    }
    
    .header-icon {
      width: 70px;
      height: 70px;
      font-size: 2.5rem;
    }
  }
</style>