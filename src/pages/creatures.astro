---
// Страница «Существа и духи»
import BaseLayout from '@layouts/BaseLayout.astro';
import CreatureCard from '@components/CreatureCard.astro';
import ElementBadge from '@components/ElementBadge.astro';
import { DANGER_LEVELS_LIST } from '@data/dangerLevels';
import { 
  HIGHER_CREATURES, 
  COMMON_CREATURES, 
  NAV_CREATURES, 
  DISTORTED_CREATURES, 
  MONSTERS,
  ALL_CREATURES
} from '@data/creatures';

const elements = ['wood', 'fire', 'earth', 'metal', 'water'] as const;
const elementNames = {
  wood: 'Дерево',
  fire: 'Огонь',
  earth: 'Земля',
  metal: 'Металл',
  water: 'Вода',
};

// Все категории для отображения
const sections = [
  { id: 'higher', title: 'Высшие сущности', icon: '⭐', creatures: HIGHER_CREATURES, color: '#d4af37' },
  { id: 'common', title: 'Обычные существа', icon: '🌿', creatures: COMMON_CREATURES, color: '#2d5a27' },
  { id: 'nav', title: 'Существа Нави', icon: '🌙', creatures: NAV_CREATURES, color: '#4a4a6a' },
  { id: 'distorted', title: 'Существа Искажённых Земель', icon: '🌀', creatures: DISTORTED_CREATURES, color: '#8b5cf6' },
  { id: 'monster', title: 'Чудовища', icon: '👹', creatures: MONSTERS, color: '#ef4444' },
];
---

<BaseLayout title="Существа и духи">
  <div class="page-header">
    <h1>🐉 Существа и духи</h1>
    <p class="page-description">
      От высших сущностей Прави до опасных чудовищ Искажённых Земель — мир Царства Пяти Начал населён удивительными созданиями
    </p>
  </div>

  <!-- Фильтры -->
  <div class="filters-section">
    <div class="filter-group">
      <span class="filter-label">Категория:</span>
      <div class="filter-buttons">
        <button class="filter-btn active" data-filter="all">Все</button>
        <button class="filter-btn" data-filter="higher">⭐ Высшие</button>
        <button class="filter-btn" data-filter="common">🌿 Обычные</button>
        <button class="filter-btn" data-filter="nav">🌙 Навь</button>
        <button class="filter-btn" data-filter="distorted">🌀 Искажённые</button>
        <button class="filter-btn" data-filter="monster">👹 Чудовища</button>
      </div>
    </div>
    
    <div class="filter-group">
      <span class="filter-label">Стихия:</span>
      <div class="filter-buttons">
        <button class="filter-btn active" data-element="all">Все</button>
        {elements.map(element => (
          <button class="filter-btn" data-element={element}>
            <ElementBadge element={element} size="small" showLabel={false} />
            {elementNames[element]}
          </button>
        ))}
      </div>
    </div>
    
    <div class="filter-group">
      <span class="filter-label">Опасность:</span>
      <div class="filter-buttons">
        <button class="filter-btn active" data-danger="all">Все</button>
        {DANGER_LEVELS_LIST.map(level => (
          <button class="filter-btn" data-danger={level.value}>
            {level.icon} {level.name}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Статистика -->
  <div class="stats-bar">
    <div class="stat">
      <span class="stat-value">{ALL_CREATURES.length}</span>
      <span class="stat-label">всего существ</span>
    </div>
    <div class="stat">
      <span class="stat-value">{sections.length}</span>
      <span class="stat-label">категорий</span>
    </div>
  </div>

  <!-- Категории существ -->
  {sections.map(section => (
    <section class="section" id={`${section.id}-section`} data-category={section.id}>
      <h2 style={`border-left-color: ${section.color}`}>
        <span class="section-icon">{section.icon}</span>
        {section.title}
      </h2>
      <div class="creatures-grid">
        {section.creatures.map(creature => (
          <CreatureCard creature={creature} />
        ))}
      </div>
    </section>
  ))}

  <!-- Цитата -->
  <div class="quote-block">
    <p class="quote-text">«Не каждое чудовище — враг. Но каждое чудовище заслуживает уважения»</p>
    <p class="quote-author">— Бестиарий Царства Пяти Начал</p>
  </div>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  
  .page-description {
    font-size: 1.1rem;
    color: var(--text-accent);
    max-width: 700px;
    margin: 0 auto;
  }
  
  .filters-section {
    background: var(--bg-secondary);
    border-radius: var(--border-radius-lg);
    padding: 1rem 1.5rem;
    margin-bottom: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    justify-content: center;
  }
  
  .filter-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  
  .filter-label {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  
  .filter-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .filter-btn {
    padding: 0.4rem 0.8rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    font-size: 0.8rem;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  
  .filter-btn:hover {
    border-color: var(--text-accent);
    color: var(--text-accent);
  }
  
  .filter-btn.active {
    background: var(--text-accent);
    border-color: var(--text-accent);
    color: var(--bg-primary);
  }
  
  .stats-bar {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 2rem;
    padding: 1rem;
    background: var(--bg-secondary);
    border-radius: var(--border-radius-lg);
  }
  
  .stat {
    text-align: center;
  }
  
  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-accent);
  }
  
  .stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-left: 0.3rem;
  }
  
  .section {
    margin-bottom: 4rem;
  }
  
  .section-icon {
    margin-right: 0.5rem;
  }
  
  .creatures-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 1.5rem;
    margin: 1.5rem 0;
  }
  
  .quote-block {
    background: linear-gradient(135deg, var(--bg-card) 0%, rgba(212, 175, 55, 0.05) 100%);
    border-left: 4px solid var(--text-accent);
    padding: 2rem;
    margin: 3rem 0;
    border-radius: var(--border-radius-md);
    text-align: center;
  }
  
  .quote-text {
    font-size: 1.2rem;
    font-style: italic;
    color: var(--text-primary);
  }
  
  .quote-author {
    margin-top: 1rem;
    color: var(--text-accent);
  }
  
  @media (max-width: 768px) {
    .creatures-grid {
      grid-template-columns: 1fr;
    }
    
    .filters-section {
      flex-direction: column;
      align-items: stretch;
    }
    
    .filter-group {
      justify-content: space-between;
    }
    
    .filter-buttons {
      justify-content: center;
    }
    
    .quote-text {
      font-size: 1rem;
    }
  }
</style>

<script>
  // Фильтрация существ
  let currentCategory = 'all';
  let currentElement = 'all';
  let currentDanger = 'all';
  
  function filterCards() {
    const sections = document.querySelectorAll('.section');
    
    sections.forEach(section => {
      const sectionCategory = section.id?.replace('-section', '');
      const cards = section.querySelectorAll('.creature-card');
      
      let visibleCount = 0;
      cards.forEach(card => {
        const cardElement = card.classList.contains('creature-wood') ? 'wood' :
                           card.classList.contains('creature-fire') ? 'fire' :
                           card.classList.contains('creature-earth') ? 'earth' :
                           card.classList.contains('creature-metal') ? 'metal' :
                           card.classList.contains('creature-water') ? 'water' : null;
        
        const dangerSpan = card.querySelector('.danger-badge');
        let cardDanger = 'low';
        if (dangerSpan) {
          const dangerText = dangerSpan.textContent || '';
          if (dangerText.includes('Нет')) cardDanger = 'none';
          else if (dangerText.includes('Низкая')) cardDanger = 'low';
          else if (dangerText.includes('Средняя')) cardDanger = 'medium';
          else if (dangerText.includes('Высокая')) cardDanger = 'high';
          else if (dangerText.includes('Очень')) cardDanger = 'very-high';
          else if (dangerText.includes('Бездна')) cardDanger = 'abyss';
        }
        
        const categoryMatch = currentCategory === 'all' || currentCategory === sectionCategory;
        const elementMatch = currentElement === 'all' || cardElement === currentElement;
        const dangerMatch = currentDanger === 'all' || cardDanger === currentDanger;
        
        const isVisible = categoryMatch && elementMatch && dangerMatch;
        card.style.display = isVisible ? '' : 'none';
        if (isVisible) visibleCount++;
      });
      
      // Скрываем секцию, если в ней нет видимых карточек
      const sectionTitle = section.querySelector('h2');
      if (sectionTitle) {
        section.style.display = visibleCount > 0 ? '' : 'none';
      }
    });
  }
  
  // Обработчики для кнопок
  document.querySelectorAll('[data-filter]').forEach(btn => {
    btn.addEventListener('click', () => {
      currentCategory = btn.dataset.filter;
      document.querySelectorAll('[data-filter]').forEach(b => b.classList.remove('active'));
      document.querySelectorAll(`[data-filter="${currentCategory}"]`).forEach(b => b.classList.add('active'));
      filterCards();
    });
  });
  
  document.querySelectorAll('[data-element]').forEach(btn => {
    btn.addEventListener('click', () => {
      currentElement = btn.dataset.element;
      document.querySelectorAll('[data-element]').forEach(b => b.classList.remove('active'));
      document.querySelectorAll(`[data-element="${currentElement}"]`).forEach(b => b.classList.add('active'));
      filterCards();
    });
  });
  
  document.querySelectorAll('[data-danger]').forEach(btn => {
    btn.addEventListener('click', () => {
      currentDanger = btn.dataset.danger;
      document.querySelectorAll('[data-danger]').forEach(b => b.classList.remove('active'));
      document.querySelectorAll(`[data-danger="${currentDanger}"]`).forEach(b => b.classList.add('active'));
      filterCards();
    });
  });
</script>