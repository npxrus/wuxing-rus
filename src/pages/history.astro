---
// Страница «История и хронология»
import BaseLayout from '@layouts/BaseLayout.astro';
import Timeline from '@components/Timeline.astro';
import { ERAS, HISTORICAL_FIGURES } from '@data/history';
---

<BaseLayout title="История и хронология">
  <div class="page-header">
    <h1>📜 История Царства Пяти Начал</h1>
    <p class="page-description">
      Летосчисление ведётся от Пробуждения Мирового Дуба. Текущий год — <strong>7 843 Лето Пробуждения Дуба</strong>
    </p>
  </div>

  <!-- Таймлайн -->
  <section class="section">
    <h2>📅 Хронология эпох</h2>
    <p>
      История Царства разделена на пять великих эпох, каждая из которых длилась сотни и тысячи лет.
      От Первотворения до современной эпохи Угрозы.
    </p>
    <Timeline eras={ERAS} />
  </section>

  <!-- Исторические личности -->
  <section class="section">
    <h2>👥 Великие личности прошлого</h2>
    <p>
      Герои, волхвы и князья, чьи имена вписаны в свитки истории.
    </p>
    <div class="figures-grid">
      {HISTORICAL_FIGURES.map(figure => (
        <div class="figure-card">
          <div class="figure-icon">{figure.icon}</div>
          <div class="figure-info">
            <div class="figure-name">{figure.name}</div>
            <div class="figure-era">{figure.era}</div>
            <div class="figure-role">{figure.role}</div>
            <div class="figure-description">{figure.description}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Счётчик лет -->
  <section class="section stats-section">
    <h2>📊 Статистика истории</h2>
    <div class="history-stats">
      <div class="stat-card">
        <div class="stat-number">7 843</div>
        <div class="stat-label">Лето от Пробуждения Дуба</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">5</div>
        <div class="stat-label">Великих эпох</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">31+</div>
        <div class="stat-label">Ключевых событий</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">7</div>
        <div class="stat-label">Легендарных героев</div>
      </div>
    </div>
  </section>

  <!-- Цитата -->
  <div class="quote-block">
    <p class="quote-text">«История — это не прошлое. Это ключ к будущему»</p>
    <p class="quote-author">— Вещий Кудеяр</p>
  </div>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .page-description {
    font-size: 1.1rem;
    color: var(--text-accent);
    max-width: 700px;
    margin: 0 auto;
  }
  
  .section {
    margin-bottom: 4rem;
  }
  
  /* Фигуры */
  .figures-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }
  
  .figure-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--bg-card);
    border-radius: var(--border-radius-md);
    padding: 1rem;
    transition: transform var(--transition-fast);
    border: 1px solid var(--border-color);
  }
  
  .figure-card:hover {
    transform: translateX(5px);
    border-color: var(--text-accent);
  }
  
  .figure-icon {
    font-size: 2rem;
  }
  
  .figure-info {
    flex: 1;
  }
  
  .figure-name {
    font-weight: 600;
    color: var(--text-accent);
    font-size: 1rem;
  }
  
  .figure-era {
    font-size: 0.7rem;
    color: var(--text-muted);
  }
  
  .figure-role {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 0.2rem;
  }
  
  .figure-description {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }
  
  /* Статистика */
  .history-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.5rem;
    margin: 1.5rem 0;
  }
  
  .stat-card {
    background: var(--bg-card);
    border-radius: var(--border-radius-lg);
    padding: 1.5rem;
    text-align: center;
    border: 1px solid var(--border-color);
  }
  
  .stat-card:hover {
    border-color: var(--text-accent);
  }
  
  .stat-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-accent);
  }
  
  .stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }
  
  /* Цитата */
  .quote-block {
    background: linear-gradient(135deg, var(--bg-card) 0%, rgba(212, 175, 55, 0.05) 100%);
    border-left: 4px solid var(--text-accent);
    padding: 2rem;
    margin: 3rem 0;
    border-radius: var(--border-radius-md);
    text-align: center;
  }
  
  .quote-text {
    font-size: 1.2rem;
    font-style: italic;
    color: var(--text-primary);
  }
  
  .quote-author {
    margin-top: 1rem;
    color: var(--text-accent);
  }
  
  @media (max-width: 768px) {
    .figures-grid {
      grid-template-columns: 1fr;
    }
    
    .figure-card {
      flex-direction: column;
      text-align: center;
    }
    
    .quote-text {
      font-size: 1rem;
    }
  }
</style>